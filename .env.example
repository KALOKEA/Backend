# ===========================================================================
# KALOKEA BACKEND — Environment Variables
# Copy to .env and fill in real values. App fails fast on missing REQUIRED vars
# (see src/config/env.validation.ts). NEVER commit the real .env.
# ===========================================================================

# --- Server ---------------------------------------------------------------
PORT=3001
NODE_ENV=development

# --- CORS -----------------------------------------------------------------
# Comma-separated list of allowed frontend origins (no trailing slash).
ALLOWED_ORIGINS=http://localhost:3000,https://kalokea.com,https://www.kalokea.com,https://kalokea.pages.dev

# --- Supabase (REQUIRED) --------------------------------------------------
# Project ref: ygxbqdwtaryciskskokc
SUPABASE_URL=https://ygxbqdwtaryciskskokc.supabase.co
# Service-role key — full DB access, RLS bypassed in code. KEEP SECRET.
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# --- JWT (REQUIRED) -------------------------------------------------------
# Use long random strings; the two MUST differ.
JWT_SECRET=your-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars

# --- Razorpay (payments) --------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# --- Brevo (transactional email) ------------------------------------------
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=support@kalokea.com
BREVO_SENDER_NAME=Kalokea
# Receives admin new-order / low-stock notifications.
ADMIN_EMAIL=support@kalokea.com

# --- Cloudinary (image uploads) -------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# --- URLs (used in email links) -------------------------------------------
SITE_URL=https://kalokea.com
BACKEND_URL=https://api.kalokea.com

# --- Sentry (error monitoring) --------------------------------------------
SENTRY_DSN=https://your-key@oXXXXXXX.ingest.sentry.io/XXXXXXX
